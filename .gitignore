# venv / caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.uv/
*.egg-info/

# large raw data (fetch scripts regenerate); small vendored samples are force-added
data/raw/
data/cache/
*.wav
*.flac
!data/samples/*.wav
!data/samples/*.flac

# results: figures + JSON summaries are versioned; bulky intermediates are not
results/cache/

# latex build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls

# secrets / local
.env
*_secret*

# rendered preview pngs
paper/pg-*.png
paper/rp*.png

# server-deploy provenance stamp (generated by scripts/deploy.sh)
GIT_COMMIT
_upload.tgz

# nondeterministic advisory citation report (allowlist is the committed record)
results/citation_integrity.json
arc_env.sh
*.arc_cred
config.arc.yaml
arc_runs/
